# Copilot-native artifacts (.github/agents/ wrappers, .github/skills/ mirror) are no longer generated
# — both Claude Code and VS Code/Copilot read `.claude/` directly. Any stale local copies from an old
# sync run stay ignored below so they can't be committed.
.github/agents/
.github/skills/

# Temporary git worktrees used for cross-branch review/comparison (scratch; never committed).
/.worktrees/

# Python bytecode
__pycache__/
*.pyc

# Local Claude Code permission overrides — untracked operator-machine state (can carry env/hooks/
# plugin keys, not just Bash allow-rules). It is read from the CWD on every eval trial regardless of
# CLAUDE_CONFIG_DIR (see evals/clean_room.py's warn_if_settings_local_present()) — never commit it.
.claude/settings.local.json

