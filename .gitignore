# Copilot-native artifacts (.github/agents/ wrappers, .github/skills/ mirror) are no longer generated
# — both Claude Code and VS Code/Copilot read `.claude/` directly. Any stale local copies from an old
# sync run stay ignored below so they can't be committed.
.github/agents/
.github/skills/

# Temporary git worktrees used for cross-branch review/comparison (scratch; never committed).
/.worktrees/

# Python bytecode
__pycache__/
*.pyc

# production-change-gate clearance sentinel — a LOCAL, per-session signal that the gate was
# cleared. Never commit it: a committed .gate-cleared would silently clear the prod-change
# speed-bump for every checkout. (scripts/production-change-guard.py reads ./.gate-cleared.)
.gate-cleared
**/.gate-cleared
