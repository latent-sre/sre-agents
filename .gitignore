# Copilot-native agent wrappers (.github/agents/*.agent.md) are generated by scripts/sync-copilot.*
# from the canonical .claude/ definitions and are COMMITTED so CI can diff them against a fresh
# regeneration and fail on drift (the "Copilot drift gate"). Don't hand-edit them — edit .claude/ and
# re-run scripts/sync-copilot.sh (or .ps1). The .github/skills/ SKILL.md mirror is NOT committed
# (it's a byte-identical copy of .claude/skills/, which Copilot reads directly) — see below.

# Temporary git worktrees used for cross-branch review/comparison (scratch; never committed).
/.worktrees/

# Python bytecode
__pycache__/
*.pyc

# production-change-gate clearance sentinel — a LOCAL, per-session signal that the gate was
# cleared. Never commit it: a committed .gate-cleared would silently clear the prod-change
# speed-bump for every checkout. (scripts/production-change-guard.py reads ./.gate-cleared.)
.gate-cleared
**/.gate-cleared

# Copilot SKILL mirror — optional local artifact, regenerated by sync-copilot.* into a gitignored
# path. Copilot reads .claude/skills/ directly, so this byte-identical copy is not committed (only the
# .agent.md wrappers under .github/agents/ are, since those carry real tool-translation).
.github/skills/
